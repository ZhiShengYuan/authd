{
    "swagger": "2.0",
    "info": {
        "description": "Authentication gateway endpoints for inline authorization, challenge issuance, and PoW verification.",
        "title": "Mirror Guard Auth Gateway API",
        "contact": {},
        "license": {
            "name": "Apache-2.0",
            "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "paths": {
        "/api/auth_inline": {
            "get": {
                "description": "Public API contract documents GET semantics for Nginx auth_request integrations. Required headers: X-Real-IP and X-URL. Optional headers: X-UA and X-Request-ID. Optional Cookie header carries the auth cookie and any issued cookie uses Secure=true, HttpOnly=true, SameSite=Lax.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Inline authorization decision",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Client IP address",
                        "name": "X-Real-IP",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Original requested URL",
                        "name": "X-URL",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Client user agent",
                        "name": "X-UA",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Request correlation identifier",
                        "name": "X-Request-ID",
                        "in": "header"
                    },
                    {
                        "type": "string",
                        "description": "Auth cookie for token validation",
                        "name": "Cookie",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Allowed"
                    },
                    "302": {
                        "description": "Redirect (Location header)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "Challenge required (X-Auth-Action: challenge)",
                        "schema": {
                            "$ref": "#/definitions/apidoc.AuthInlineError"
                        }
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "444": {
                        "description": "Connection dropped (Nginx-specific)"
                    },
                    "503": {
                        "description": "Service unavailable"
                    }
                }
            }
        },
        "/api/challenge": {
            "get": {
                "description": "Returns PoW challenge parameters for a protected target. Requires X-Real-IP and X-URL headers; X-UA is optional.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Issue proof-of-work challenge",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Client IP address",
                        "name": "X-Real-IP",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Original requested URL",
                        "name": "X-URL",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Client user agent",
                        "name": "X-UA",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/apidoc.ChallengeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apidoc.ChallengeError"
                        }
                    },
                    "405": {
                        "description": "Method not allowed"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/api/verify_pow": {
            "post": {
                "description": "Validates submitted PoW, prevents nonce replay, then redirects with an auth cookie. Requires X-Real-IP header; X-UA is optional.",
                "consumes": [
                    "application/json",
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Verify proof-of-work submission",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Client IP address",
                        "name": "X-Real-IP",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Client user agent",
                        "name": "X-UA",
                        "in": "header"
                    },
                    {
                        "description": "PoW submission",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/apidoc.VerifyPoWRequest"
                        }
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirect to target with cookie (Set-Cookie and Location headers)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/apidoc.VerifyPoWError"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/apidoc.VerifyPoWError"
                        }
                    },
                    "405": {
                        "description": "Method not allowed"
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/apidoc.VerifyPoWError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "apidoc.AuthInlineError": {
            "type": "object",
            "properties": {
                "error": {
                    "description": "Error is a machine-readable error code for auth inline failures.",
                    "type": "string",
                    "example": "challenge_required"
                },
                "message": {
                    "description": "Message is a human-readable summary of the auth inline failure.",
                    "type": "string",
                    "example": "Client must complete a proof-of-work challenge"
                }
            }
        },
        "apidoc.ChallengeError": {
            "type": "object",
            "properties": {
                "error": {
                    "description": "Error is a machine-readable error code for challenge endpoint failures.",
                    "type": "string",
                    "example": "invalid_client_ip"
                },
                "message": {
                    "description": "Message is a human-readable summary of why challenge generation failed.",
                    "type": "string",
                    "example": "Unable to determine client subnet"
                }
            }
        },
        "apidoc.ChallengeResponse": {
            "type": "object",
            "properties": {
                "difficulty": {
                    "description": "Difficulty is the required number of leading zero bits/characters for PoW validation.",
                    "type": "integer",
                    "example": 5
                },
                "prefix": {
                    "description": "Prefix is the signed challenge prefix tied to client subnet and target.",
                    "type": "string",
                    "example": "1700000000:abcdef12:signaturehex"
                },
                "target": {
                    "description": "Target is the protected resource URL that this challenge authorizes when solved.",
                    "type": "string",
                    "example": "https://mirror.example.com/file.iso"
                }
            }
        },
        "apidoc.VerifyPoWError": {
            "type": "object",
            "properties": {
                "error": {
                    "description": "Error is a machine-readable error code for programmatic handling.",
                    "type": "string",
                    "example": "invalid_pow"
                },
                "message": {
                    "description": "Message is a human-readable description of the verification failure.",
                    "type": "string",
                    "example": "The submitted nonce does not satisfy the difficulty requirement"
                }
            }
        },
        "apidoc.VerifyPoWRequest": {
            "type": "object",
            "properties": {
                "nonce": {
                    "description": "Nonce is the client-computed value that satisfies the requested PoW difficulty.",
                    "type": "string",
                    "example": "42"
                },
                "prefix": {
                    "description": "Prefix is the signed challenge prefix returned by the challenge endpoint.",
                    "type": "string",
                    "example": "1700000000:abcdef12:signaturehex"
                },
                "target_uri": {
                    "description": "TargetURI is the original protected URL to redirect to after successful verification.",
                    "type": "string",
                    "example": "https://mirror.example.com/file.iso"
                }
            }
        }
    }
}